<h3>Watched</h3>
    <ul class="row" id="posterRow">
      <% @watched.each do |movie| %>
        <li>
          <a href="/movies/<%= movie['id'] %>">
            <img class="posterimg" src="<%= movie['poster'] %>" alt="<%= movie['name'] %>">
          </a>
        </li>
      <% end %>
    </ul>
