<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PROFlix</title>
    <link rel="stylesheet" type="text/css" href="/style.css?<%=Time.now.to_i%>">
</head>
  
<body>

<h1>PROFlix</h1>


<% if @current_user %>
    <ul class="account-tab"> 
      <ul><a href="/userpage" id="whitetext">My Profile</a></ul>
    </ul>
<% else %>
  <ul class="account-tab">
    <ul><a href="/login" id="whitetext">Log In</a></ul>
    <ul><a href="/users/new" id="whitetext">Sign Up</a></ul>
  </ul>
<% end %>

<%= yield %>

</body>
</html>
